#!/bin/bash
# Pre-push hook: run all tests before push
# Install: cp scripts/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

set -e

echo "🧪 Running flutter test..."
export LD_LIBRARY_PATH="/home/openclaw:$LD_LIBRARY_PATH"
/home/openclaw/flutter/bin/flutter test
echo "✅ All tests passed. Pushing..."
